## Visual Studio
## Based on https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# =========================
# User-specific files
# =========================
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.env

# Mono / Xamarin
*.userprefs
mono_crash.*

# =========================
# Build output
# =========================
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
[Aa][Rr][Mm]64[Ee][Cc]/
bld/
bin/
obj/
out/
log/
logs/

# Bin folders everywhere
**/[Bb]in/*

# =========================
# VS / IDE
# =========================
.vs/
Generated\ Files/

# VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# =========================
# Test / Coverage
# =========================
TestResult*/
*.trx
*.coverage
*.coveragexml
coverage*.json
coverage*.xml
coverage*.info

# =========================
# Logs / temp
# =========================
*.log
*.tlog
*.tmp
*.cache
*~
~$*

# =========================
# Compiled / binary
# =========================
*.obj
*.pdb
*.ipdb
*.pgc
*.pgd
*.ilk
*.idb
*.dll
*.exe

# =========================
# NuGet
# =========================
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/

*.nuget.props
*.nuget.targets

# =========================
# Node
# =========================
node_modules/

# =========================
# Python
# =========================
__pycache__/
*.pyc

# =========================
# MSIX / Appx packaging
# =========================
AppPackages/
BundleArtifacts/

*.appx
*.appxbundle
*.msix
*.msixbundle
*.appxupload
*.msixupload
*.appxsym

# =========================
# Signing certs (IMPORTANT)
# =========================
*.pfx
*.p12
*.snk
*.pvk
*.key

# =========================
# Azure / publish
# =========================
*.publish.xml
*.pubxml
*.publishproj
PublishScripts/

# =========================
# Misc tools
# =========================
_ReSharper*/
*.DotSettings.user
_NCrunch_*
.ncrunch*
.axoCover/*
BenchmarkDotNet.Artifacts/

# =========================
# SQL
# =========================
*.mdf
*.ldf
*.ndf

# =========================
# VS Extensions / installers
# =========================
*.vsix
*.cab
*.msi
*.msm
*.msp

